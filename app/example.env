# ─────────────────────────────────────────────────────────────
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored; `example.env` is committed as a template.
# ─────────────────────────────────────────────────────────────


# ─────────────────────────────────────────────────────────────
# Supabase — safe to expose to the browser (once RLS is correctly
# configured per supabase/rls_policies.sql).
# Get from: Supabase project → Settings → API
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ─────────────────────────────────────────────────────────────
# Supabase service role — server-side only, never sent to browser.
# Bypasses RLS. Treat like a root password.
# ─────────────────────────────────────────────────────────────
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─────────────────────────────────────────────────────────────
# Admin dashboard password (used at /admin).
# Single shared admin credential. Anyone with this can log in as admin.
# ─────────────────────────────────────────────────────────────
ADMIN_PASSWORD=change-me-to-a-strong-password

# ─────────────────────────────────────────────────────────────
# HMAC secret for ALL session cookies (admin, customer, driver,
# waiter, kitchen, POS). Single secret signs the unified
# `<exp>|<id>|<role>|<sig>` token format used everywhere.
# Generate with: openssl rand -hex 64
# ─────────────────────────────────────────────────────────────
AUTH_JWT_SECRET=replace-with-a-long-random-secret-at-least-64-chars

# ─────────────────────────────────────────────────────────────
# Legacy alias — read as a fallback when AUTH_JWT_SECRET is not set.
# Existing deployments can keep both for back-compat; new deployments
# only need AUTH_JWT_SECRET above. Safe to leave blank or remove if
# you're starting fresh.
# ─────────────────────────────────────────────────────────────
ADMIN_JWT_SECRET=

# ─────────────────────────────────────────────────────────────
# Canonical site URL (used for OAuth callbacks & password-reset links).
# Local dev:  http://localhost:3000
# Production: https://yourdomain.com
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────
# Google OAuth — optional; enables "Sign in with Google".
# Get from: Google Cloud Console → APIs & Services → Credentials
# Authorised redirect URI: {NEXT_PUBLIC_SITE_URL}/api/auth/google/callback
# Customers who sign in with Google have email_verified=true
# automatically and skip the email-verification flow.
# Leave blank to disable Google sign-in.
# ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─────────────────────────────────────────────────────────────
# Email provider — pick ONE: Resend (recommended) OR SMTP (below).
# If both are set, Resend wins.
#
# Resend setup:
#   1. Sign up at https://resend.com
#   2. Dashboard → API Keys → Create API Key
#   3. To send from your own domain, verify it under Domains.
#      Until then, leave EMAIL_FROM blank and Resend's shared
#      `onboarding@resend.dev` sender is used automatically.
# ─────────────────────────────────────────────────────────────
RESEND_API_KEY=

# Sender details — used by both Resend and SMTP.
EMAIL_FROM=
EMAIL_FROM_NAME=

# ─────────────────────────────────────────────────────────────
# SMTP fallback — used only if RESEND_API_KEY is empty.
# Works with any SMTP provider (Gmail, SendGrid, Mailgun, Postmark, …).
#
# Examples:
#   Gmail:  host smtp.gmail.com,  port 587, user <your@gmail>, pass <app-password>
#   Resend: host smtp.resend.com, port 587, user "resend",     pass <api-key>
# ─────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ─────────────────────────────────────────────────────────────
# Postgres connection string — only needed for `npm run db:migrate`
# (applies supabase/schema.sql). The app itself does NOT use this
# at runtime — it talks to Supabase via the keys above.
# Get from: Supabase Dashboard → Connect → Direct (or Session pooler).
# Special chars in the password MUST be URL-encoded.
# Example: postgresql://postgres.<ref>:<encoded-pw>@<host>:5432/postgres
# ─────────────────────────────────────────────────────────────
DATABASE_URL=


# ─────────────────────────────────────────────────────────────
# Credential storage by role — for reference:
#
#   Admin       env var ADMIN_PASSWORD (above)
#   Customer    bcrypt hash in customers.password_hash
#               (set by customer via /login register, or by Google OAuth)
#   Driver      bcrypt hash in drivers.password_hash
#               (set by admin via Admin → User Management)
#   POS staff   4-digit PIN in app_settings.data.pos_staff[].pin
#               (set by admin via Admin → POS Staff)
#   Waiter      4-digit PIN in app_settings.data.waiters[].pin
#               (set by admin via Admin → Staff & Tables)
#   Kitchen     4-digit PIN in app_settings.data.kitchenStaff[].pin
#               (set by admin via Admin → Kitchen Staff)
#
# No hardcoded staff or PINs exist in the codebase. A fresh install
# cannot use POS / waiter / kitchen until an admin configures staff
# via the admin panel.
# ─────────────────────────────────────────────────────────────


# ─────────────────────────────────────────────────────────────
# Stripe — required for card payments (no SDK is loaded unless
# STRIPE_SECRET_KEY is set). PayPal remains unimplemented; orders
# can still be placed via Cash without any Stripe config.
#
# Setup:
#   1. Sign up / sign in at https://dashboard.stripe.com
#   2. Toggle to TEST mode (top right) while developing.
#   3. Dashboard → Developers → API keys
#      - "Publishable key" (pk_test_…)  → NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY
#      - "Secret key"      (sk_test_…)  → STRIPE_SECRET_KEY
#   4. For local webhook testing, install Stripe CLI then run:
#        stripe listen --forward-to localhost:3000/api/webhooks/stripe
#      The CLI prints a whsec_… value — paste it as STRIPE_WEBHOOK_SECRET.
#   5. For production, Dashboard → Developers → Webhooks → Add endpoint
#      URL: https://YOUR_DOMAIN/api/webhooks/stripe
#      Events: payment_intent.succeeded, payment_intent.payment_failed,
#              charge.refunded
#      Copy the signing secret into STRIPE_WEBHOOK_SECRET on your host.
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─────────────────────────────────────────────────────────────
# Apple Pay domain verification (optional — only needed if you want
# Apple Pay to show in the PaymentElement for Safari users).
#
# Setup:
#   1. Stripe Dashboard → Settings → Payment methods → Apple Pay
#      → "Add a new domain" → enter your domain → Download verification file.
#   2. The downloaded file is a single long string. Open it, copy the contents,
#      paste them as the value below (no quotes, no whitespace).
#   3. Deploy. Then click "Verify" in Stripe Dashboard. Stripe fetches
#      https://YOUR_DOMAIN/.well-known/apple-developer-merchantid-domain-association
#      and verifies the body matches the file it issued.
# Leave blank to disable Apple Pay.
# ─────────────────────────────────────────────────────────────
APPLE_PAY_DOMAIN_ASSOCIATION=

# ─────────────────────────────────────────────────────────────
# NOTE: PayPal is exposed in the admin Integrations panel but no
# SDK is wired up yet. PayPal buttons are hidden from the customer
# checkout. Implement /api/payments/paypal and remove the filter in
# CheckoutModal.tsx when you're ready to enable it.
# ─────────────────────────────────────────────────────────────
