    "android:build": "npm run build && npx cap sync android"
  },
  "dependencies": {
    "@capacitor-community/sqlite": "^7.0.3",
    "@paypal/react-paypal-js": "^9.2.0",
    "@stripe/react-stripe-js": "^6.3.0",
    "@stripe/stripe-js": "^9.5.0",
    "@supabase/supabase-js": "^2.108.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/qrcode": "^1.5.6",
    "bcryptjs": "^3.0.3",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.8.0",
    "next": "^15.5.18",
    "nodemailer": "^8.0.5",
    "qrcode": "^1.5.4",
    "react": "^19.1.7",
    "react-dom": "^19.1.7",
    "react-leaflet": "^5.0.0",
    "resend": "^4.0.0",
    "stripe": "^22.1.1",
    "zod": "^4.4.3"
