# ─────────────────────────────────────────────────────────────
# Single-Restaurant Food Ordering System — example env vars
# Copy to .env.local and fill in your own values. Never commit .env.local.
# ─────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────
# URL + anon key are safe to expose to the browser (they're in the JS bundle).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...

# Service role key — server-side only. Never sent to the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...

# Postgres direct connection — used by `npm run db:migrate` / `db:seed-demo`.
# Find in Supabase Dashboard → Project Settings → Database → Connection string.
# URL-encode any special characters in the password.
DATABASE_URL=postgresql://postgres.<project>:<password>@<region>.pooler.supabase.com:5432/postgres


# ── Site URL ─────────────────────────────────────────────────
# Used by OAuth callbacks, password-reset links, and email "view in browser" URLs.
NEXT_PUBLIC_SITE_URL=http://localhost:3000


# ── Admin dashboard ──────────────────────────────────────────
# Single password for /admin login.
ADMIN_PASSWORD=change-me


# ── Session secrets ──────────────────────────────────────────
# Generate with: openssl rand -hex 64  (for AUTH_JWT_SECRET)
# Generate with: openssl rand -hex 32  (for ADMIN_JWT_SECRET)
# Used to HMAC-sign httpOnly session cookies for customer / driver / staff / admin.
AUTH_JWT_SECRET=replace-with-64-byte-hex
ADMIN_JWT_SECRET=replace-with-32-byte-hex


# ── Email (Resend — recommended) ─────────────────────────────
# Pick ONE: Resend (this block) OR SMTP (next block). If both are set, Resend wins.
#
# 1. Sign up at https://resend.com
# 2. Dashboard → API Keys → Create API Key
# 3. To send from your own domain, verify it under Domains. Until then, leave
#    EMAIL_FROM blank and Resend's shared `onboarding@resend.dev` is used.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sender details — both modes use these.
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=Your Restaurant


# ── Email (SMTP fallback) ────────────────────────────────────
# Used only if RESEND_API_KEY is empty. Works with any SMTP provider
# (Gmail, SendGrid, Mailgun, Postmark, Resend's SMTP endpoint, ...).
#
# Examples:
#   Gmail:  host smtp.gmail.com,  port 587, user <your@gmail>, pass <app-password>
#   Resend: host smtp.resend.com, port 587, user "resend",     pass <api-key>
#
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=


# ── Google OAuth (optional) ──────────────────────────────────
# Enables "Sign in with Google" on the customer auth page. Leave blank to disable.
# Configure at https://console.cloud.google.com → APIs & Services → Credentials.
# Authorised redirect URI: {NEXT_PUBLIC_SITE_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# ── Payments (optional) ──────────────────────────────────────
# Stripe public key is exposed via app_settings.data.stripePublicKey, not here.
# The secret + PayPal credentials stay server-side.
STRIPE_SECRET_KEY=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
