# ============================================================================
# .env.capacitor.example — template for the Android POS APK build config.
#
# Copy this to `.env.capacitor` (gitignored) and fill in the PRODUCTION values.
# `npm run build:capacitor` loads `.env.capacitor` and applies it to the static
# export — OVERRIDING .env.local for the APK build ONLY. It does NOT affect
# `npm run dev` or the website build.
#
# Get the prod values from the server's /var/www/direct-dine/app/.env.local
#
# ⚠️  NEVER put SUPABASE_SERVICE_ROLE_KEY here — it must never ship in a client.
# ============================================================================

# Backend the app's /api calls hit (sales, staff, customers, login, …).
CAPACITOR_API_URL=https://demo.directdine.tech

# Supabase the app's DIRECT reads + realtime hit (settings, menu, dining tables).
# Use the PRODUCTION project's values — NOT the local-dev project.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
