<?xml version="1.0" encoding="utf-8"?>
<!--
  Network Security Config for the Restaurant POS Android app.

  Place this file at: android/app/src/main/res/xml/network_security_config.xml
  Reference it in AndroidManifest.xml:
    <application android:networkSecurityConfig="@xml/network_security_config" ...>

  Policy:
  - Cleartext (HTTP) is permitted globally because:
    (1) Local dev runs against http://192.168.x.x:3000 — must work
    (2) Production runs against an HTTPS URL anyway — the cleartext PERMIT
        doesn't FORCE plaintext; the URL itself dictates the scheme
    (3) The TcpPrinterPlugin needs HTTP socket access to LAN printers on
        port 9100 — that's a permanent production requirement
  - We do NOT use Android's <domain> element for IP-range whitelisting
    because <domain> does exact-host matching only — it doesn't support
    CIDR or wildcards. Listing 192.168.1.0 does NOT match 192.168.1.16.
    A permissive base-config is the only setting that actually works
    across every LAN.
-->
<network-security-config>

    <!-- Global default: cleartext PERMITTED. Production URLs are HTTPS so
         this doesn't downgrade them; dev URLs and LAN printer sockets all
         work. -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

</network-security-config>
